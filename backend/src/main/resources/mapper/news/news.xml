<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="briefing.crawling.mapper.NewsMapper">
    <select id="getNewsList" resultType="News">
        SELECT *
        FROM news
        <where>
            <if test="keyword != null and keyword != ''">
                AND title LIKE CONCAT('%', #{keyword}, '%')
            </if>
        </where>
        ORDER BY write_date_time desc
    </select>

    <select id="duplicateNews" resultType="int">
        SELECT COUNT(*)
        FROM news
        WHERE url = #{url}
    </select>

    <insert id="insertNews">
        INSERT INTO news
        (
         title,
         write_date_time,
         media,
         url
        )
        VALUES
        <foreach collection="list" item="item" separator=",">
            (
            #{item.title},
            #{item.writeDateTime},
            #{item.media},
            #{item.url}
            )
        </foreach>
    </insert>

    <select id="lastReadTime" resultType="string">
        SELECT create_date_time
        FROM news
        ORDER BY create_date_time desc
        LIMIT 1
    </select>

    <select id="countSum" resultType="int">
        SELECT COUNT(*)
        FROM summary
        WHERE news_id = #{id}::bigint
    </select>

    <select id="getSummary" resultType="string">
        SELECT summary
        FROM summary
        WHERE news_id = #{id}::bigint
    </select>

    <select id="getLastDatetime" resultType="java.time.OffsetDateTime">
        SELECT MAX(create_date_time)
        FROM news
    </select>

    <insert id="insertSummary">
        INSERT INTO summary
        (news_id, summary)
        VALUES
        (#{newsId}::bigint, #{summary})
    </insert>
</mapper>